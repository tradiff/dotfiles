# vim: set ft=toml:

theme = dark:TokyoNight Night,light:TokyoNight Day
font-family = monospace
font-size = 10
gtk-wide-tabs = false
gtk-titlebar = false
background-opacity = 1
confirm-close-surface = false
mouse-scroll-multiplier = 0.5

cursor-style = bar
cursor-color = "#CD974C"
adjust-cursor-thickness = 3
cursor-style-blink = false

# Disable ligatures as described here:
# https://ghostty.org/docs/config/reference#font-feature
font-feature = -calt
font-feature = -liga
font-feature = -dlig

keybind = clear
keybind = ctrl+v=paste_from_clipboard
keybind = unconsumed:ctrl+shift+v=ignore
keybind = ctrl+shift+,=reload_config
keybind = ctrl+0=reset_font_size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+shift+p=toggle_command_palette
